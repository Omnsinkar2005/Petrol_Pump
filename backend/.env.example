# =====================================================
# Server
# =====================================================
PORT=5000
NODE_ENV=development

# =====================================================
# MySQL
# =====================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=petrol_pump_db

# =====================================================
# JWT
# =====================================================
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# =====================================================
# CORS
# =====================================================
# Comma-separated list of allowed origins (web + mobile during dev)
CORS_ORIGIN=http://localhost:5173,http://localhost:19006

# =====================================================
# Alert cron schedule (node-cron format)
# Default "0 9 * * *" = every day at 09:00
# For testing every minute use "* * * * *"
# =====================================================
ALERT_CRON_SCHEDULE=0 9 * * *
